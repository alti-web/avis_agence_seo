---
const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/comparatif-agences-seo/', label: 'Comparatif' },
  { href: '/blog/', label: 'Blog' },
  { href: '/a-propos/', label: 'À propos' },
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__logo">
      <span class="logo-icon">★</span> Avis Agence SEO
    </a>
    <nav class="site-nav" aria-label="Navigation principale">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={['site-nav__link', { active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-bg-card);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    padding-bottom: 1rem;
    gap: 2rem;
  }

  .site-header__logo {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    white-space: nowrap;
  }

  .site-header__logo:hover {
    text-decoration: none;
    color: var(--color-primary);
  }

  .logo-icon {
    color: var(--color-accent);
    font-size: 1.4rem;
  }

  .site-nav {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .site-nav__link {
    padding: 0.4rem 0.9rem;
    border-radius: var(--radius);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-light);
    transition: all 0.2s;
  }

  .site-nav__link:hover {
    background: var(--color-bg-alt);
    color: var(--color-primary);
    text-decoration: none;
  }

  .site-nav__link.active {
    background: var(--color-primary-light);
    color: var(--color-primary);
  }

  @media (max-width: 600px) {
    .site-header__inner {
      flex-direction: column;
      gap: 0.8rem;
    }
  }
</style>
